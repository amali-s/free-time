# Supabase Client (for auth, realtime, storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key

# Supabase service role key (server-only — required for Storage writes)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct PostgreSQL connection (for Drizzle ORM + PostGIS queries)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Google Places API (server-only — used to fetch space photos)
GOOGLE_PLACES_API_KEY=your_key_here
